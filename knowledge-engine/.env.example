# MCE Knowledge Engine Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Application
# =============================================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=3005

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/knowledge_engine
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# Pinecone (Vector Database)
# =============================================================================
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-environment
PINECONE_INDEX_NAME=mce-knowledge

# =============================================================================
# OpenAI (LLM)
# =============================================================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# AWS S3 (Document Storage)
# =============================================================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-southeast-2
S3_BUCKET_NAME=mce-knowledge-engine

# =============================================================================
# Security
# =============================================================================
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# Cross-Platform Integration
# =============================================================================
TATDD_ENGINE_URL=http://localhost:3000
OE_TOOLKIT_URL=http://localhost:3002
SOLAR_ANALYZER_URL=http://localhost:3003

# =============================================================================
# Confidence Scoring
# =============================================================================
CONFIDENCE_HIGH_THRESHOLD=0.8
CONFIDENCE_MEDIUM_THRESHOLD=0.5
MIN_PROJECTS_FOR_HIGH_CONFIDENCE=20
MIN_PROJECTS_FOR_MEDIUM_CONFIDENCE=5
