# Dependencies — installed fresh inside the Docker build stages
# Use ** to exclude node_modules at ANY depth (root, tools/*, oe-toolkit, etc.)
node_modules
**/node_modules
.pnpm-store
**/.pnpm-store

# Build output — rebuilt inside Docker
dist
**/dist

# Local dev / editor files
.git
.gitignore
.env
.env.*
*.local

# Test files
**/*.test.ts
**/*.spec.ts
coverage
**/coverage

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
**/*.log

# OS files
.DS_Store
Thumbs.db

# Docker files themselves (not needed in context)
Dockerfile
.dockerignore
docker-compose*.yml

# Temporary files
tmp
temp
.tmp
**/tmp
**/temp
