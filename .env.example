# ============================================================
# MCE Suite — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
# Generate secure secrets with:
#   openssl rand -hex 32
# ============================================================

# ============================================================
# SHARED INFRASTRUCTURE
# ============================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change_me_mysql_root
MYSQL_DATABASE=mce_main
MYSQL_PORT=3306

# --- PostgreSQL ---
POSTGRES_USER=mce_user
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=mce_postgres
POSTGRES_PORT=5432

# --- Neo4j ---
NEO4J_PASSWORD=change_me_neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# --- Redis ---
REDIS_PASSWORD=change_me_redis
REDIS_PORT=6379

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================================
# CLOUDFLARE TUNNEL (optional — for remote access)
# Create a tunnel at: https://dash.cloudflare.com → Zero Trust → Networks → Tunnels
# Configure two public hostnames in the tunnel:
#   tools.maincharacter.wtf   → http://nginx:80
#   sprocket.maincharacter.wtf → http://nginx:80
# ============================================================
# CLOUDFLARE_TUNNEL_TOKEN=eyJ...

# ============================================================
# OE TOOLKIT (mce-tools/oe-toolkit)
# Port: 3000
# ============================================================
# OE_TOOLKIT_DATABASE_URL=mysql://root:${MYSQL_ROOT_PASSWORD}@mysql:3306/mce_main
# OE_TOOLKIT_JWT_SECRET=change_me_oe_toolkit_jwt
# OE_TOOLKIT_LOCAL_AUTH=true
# OE_TOOLKIT_LOCAL_USERNAME=admin
# OE_TOOLKIT_LOCAL_PASSWORD=change_me_oe_toolkit_password
# APS_CLIENT_ID=your_autodesk_client_id
# APS_CLIENT_SECRET=your_autodesk_client_secret

# ============================================================
# MCE INGESTION ENGINE (mce-tools root app)
# Port: 3001
# ============================================================
# MCE_DATABASE_URL=mysql://root:${MYSQL_ROOT_PASSWORD}@mysql:3306/mce_main
# MCE_JWT_SECRET=change_me_mce_jwt
# MCE_LOCAL_AUTH=true
# MCE_LOCAL_USERNAME=admin
# MCE_LOCAL_PASSWORD=change_me_mce_password
# MCE_OLLAMA_BASE_URL=http://host.docker.internal:11434

# ============================================================
# MCE KNOWLEDGE ENGINE (mce-tools/knowledge-engine)
# Port: 3005
# ============================================================
# KNOWLEDGE_ENGINE_DATABASE_URL=postgresql+asyncpg://mce_user:${POSTGRES_PASSWORD}@postgres:5432/knowledge_engine
# KNOWLEDGE_ENGINE_JWT_SECRET=change_me_ke_jwt
# KNOWLEDGE_ENGINE_OPENAI_API_KEY=sk-...
# KNOWLEDGE_ENGINE_PINECONE_API_KEY=pcsk-...
# KNOWLEDGE_ENGINE_PINECONE_INDEX=mce-knowledge

# ============================================================
# SPROCKET AI AGENT (oe-ai-agent-2)
# Port: 3002
# ============================================================
# SPROCKET_DATABASE_URL=mysql://root:${MYSQL_ROOT_PASSWORD}@mysql:3306/agent_chat
# SPROCKET_NEO4J_URI=bolt://neo4j:7687
# SPROCKET_NEO4J_USER=neo4j
# SPROCKET_NEO4J_PASSWORD=${NEO4J_PASSWORD}
# SPROCKET_JWT_SECRET=change_me_sprocket_jwt
# SPROCKET_LOCAL_AUTH=true
# SPROCKET_LOCAL_USERNAME=admin
# SPROCKET_LOCAL_PASSWORD=change_me_sprocket_password
# SPROCKET_OPENAI_API_KEY=sk-...
# SPROCKET_ANTHROPIC_API_KEY=sk-ant-...
# SPROCKET_GOOGLE_API_KEY=AIza...

# ============================================================
# ACC WEBAPP (acc-tools/webapp)
# Port: 3003
# ============================================================
# ACC_WEBAPP_DATABASE_URL=mysql://root:${MYSQL_ROOT_PASSWORD}@mysql:3306/acc_webapp
# ACC_WEBAPP_JWT_SECRET=change_me_acc_webapp_jwt
# ACC_WEBAPP_LOCAL_AUTH=true
# ACC_WEBAPP_LOCAL_USERNAME=admin
# ACC_WEBAPP_LOCAL_PASSWORD=change_me_acc_webapp_password
# ACC_WEBAPP_OLLAMA_BASE_URL=http://host.docker.internal:11434

# ============================================================
# ACC API — Python FastAPI (acc-tools/packages/api)
# Port: 8000
# ============================================================
# ACC_API_POSTGRES_HOST=postgres
# ACC_API_POSTGRES_DB=acc_tools
# ACC_API_POSTGRES_USER=${POSTGRES_USER}
# ACC_API_POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
# ACC_API_REDIS_HOST=redis
# ACC_API_REDIS_PASSWORD=${REDIS_PASSWORD}
# ACC_API_JWT_SECRET_KEY=change_me_acc_api_jwt
