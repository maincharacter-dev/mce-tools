# ============================================================
# MCE Suite — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
# Generate secure secrets with:
#   openssl rand -hex 32
#
# KEY DESIGN DECISION:
#   All apps share SHARED_JWT_SECRET so a single login cookie
#   works across all tools (SSO via Nginx path routing).
#   LOCAL_USERNAME and LOCAL_PASSWORD are also shared.
# ============================================================

# ============================================================
# SHARED INFRASTRUCTURE
# ============================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change_me_mysql_root
MYSQL_DATABASE=mce_main
MYSQL_PORT=3306

# --- PostgreSQL ---
POSTGRES_USER=mce_user
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=mce_postgres
POSTGRES_PORT=5432

# --- Neo4j ---
NEO4J_PASSWORD=change_me_neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# --- Redis ---
REDIS_PASSWORD=change_me_redis
REDIS_PORT=6379

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================================
# SHARED AUTH (SSO across all apps)
# ============================================================
# All apps use the same JWT secret so a cookie from any app
# is valid on all others when behind the Nginx gateway.
SHARED_JWT_SECRET=change_me_shared_jwt_secret

# Shared login credentials (all apps use LOCAL_AUTH=true)
LOCAL_USERNAME=rob
LOCAL_PASSWORD=change_me_password

# ============================================================
# CLOUDFLARE TUNNEL (optional — for remote access)
# Create a tunnel at: https://dash.cloudflare.com → Zero Trust → Networks → Tunnels
# Configure public hostnames in the tunnel:
#   tools.maincharacter.wtf       → http://nginx:80
#   sprocket.maincharacter.wtf    → http://nginx:80
# ============================================================
# CLOUDFLARE_TUNNEL_TOKEN=eyJ...

# ============================================================
# OE TOOLKIT (mce-tools/oe-toolkit)
# Port: 3002 (http://localhost:3002)
# ============================================================
OE_TOOLKIT_PORT=3002
OE_TOOLKIT_DATABASE=oe_toolkit
# APS (Autodesk Platform Services) — optional, for ACC integration
APS_CLIENT_ID=your_autodesk_client_id
APS_CLIENT_SECRET=your_autodesk_client_secret

# ============================================================
# MCE WORKSPACE (mce-tools root app — the ingestion/workspace engine)
# Access: http://localhost:3001 (direct) or http://localhost:3000/workspace/ (via nginx)
# ============================================================
MCE_WORKSPACE_PORT=3001
MCE_WORKSPACE_DATABASE=mce_workspace

# OpenAI API key for AI document extraction (uses gpt-4o-mini)
# Leave blank to fall back to the built-in Forge API (no key needed)
MCE_WORKSPACE_OPENAI_API_KEY=sk-...

# Mapbox token for project location maps in the workspace UI
# Get a free token at: https://account.mapbox.com/
MAPBOX_TOKEN=pk.eyJ1...

# Ollama (optional — local LLM, only used when OPENAI_API_KEY is blank)
# Defaults to host.docker.internal:11434 (Ollama running on the host machine)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ============================================================
# MCE KNOWLEDGE ENGINE (mce-tools/knowledge-engine)
# Port: 8000 (http://localhost:8000)
# ============================================================
KNOWLEDGE_ENGINE_PORT=8000
KNOWLEDGE_ENGINE_DATABASE=knowledge_engine
KNOWLEDGE_ENGINE_OPENAI_API_KEY=sk-...
# KNOWLEDGE_ENGINE_PINECONE_API_KEY=pcsk-...
# KNOWLEDGE_ENGINE_PINECONE_INDEX=mce-knowledge

# ============================================================
# SPROCKET AI AGENT (oe-ai-agent-2)
# Port: 3010 (http://localhost:3010)
# ============================================================
SPROCKET_PORT=3010
MYSQL_USER=agent
MYSQL_PASSWORD=change_me_mysql_agent
MYSQL_DATABASE=agent_chat
SPROCKET_JWT_SECRET=${SHARED_JWT_SECRET}
SPROCKET_USERNAME=${LOCAL_USERNAME}
SPROCKET_PASSWORD=${LOCAL_PASSWORD}
SPROCKET_OPENAI_API_KEY=sk-...
SPROCKET_ANTHROPIC_API_KEY=sk-ant-...
SPROCKET_GOOGLE_API_KEY=AIza...

# ============================================================
# ACC WEBAPP (acc-tools/webapp) — Phase 4
# Port: 3003
# ============================================================
# ACC_WEBAPP_PORT=3003
# ACC_WEBAPP_DATABASE=acc_webapp

# ============================================================
# ACC API — Python FastAPI (acc-tools/packages/api) — Phase 4
# Port: 8001
# ============================================================
# ACC_API_PORT=8001
# ACC_API_POSTGRES_DB=acc_tools
# ACC_API_JWT_SECRET_KEY=${SHARED_JWT_SECRET}
